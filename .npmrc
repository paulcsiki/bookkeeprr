auto-install-peers=true
strict-peer-dependencies=false
prefer-frozen-lockfile=true
shamefully-hoist=false
# Repo-local pnpm content store. Default ~/.local/share/pnpm/store puts the
# content outside GitLab CI's cache:paths root, so every job logged
# "WARNING: .pnpm-store: no matching files" and silently re-downloaded the
# full dep tree every run. Pinning it here makes the per-job cache actually
# round-trip across pipelines.
store-dir=.pnpm-store
