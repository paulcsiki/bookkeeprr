<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>_comment</key>
	<string>Operator: replace with the real GoogleService-Info.plist from Firebase Console (Project Settings -&gt; Your apps -&gt; iOS) and drop the .example suffix. The real file is .gitignored and never committed. CI copies this stub for unsigned debug/simulator builds (the Xcode project lists the plist as a build input even though Firebase isn't exercised); release builds decode the real plist from GOOGLE_SERVICE_INFO_PLIST_B64. Values below are well-formed placeholders, not a real Firebase project.</string>
	<key>API_KEY</key>
	<string>placeholder-api-key</string>
	<key>GCM_SENDER_ID</key>
	<string>000000000000</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.bookkeeprr.app</string>
	<key>PROJECT_ID</key>
	<string>bookkeeprr</string>
	<key>STORAGE_BUCKET</key>
	<string>bookkeeprr.appspot.com</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<false/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<false/>
	<key>GOOGLE_APP_ID</key>
	<string>1:000000000000:ios:0000000000000000000000</string>
</dict>
</plist>
