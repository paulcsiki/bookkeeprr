# Path for the SQLite DB file. Defaults to /config/bookkeeprr.db in prod,
# ./bookkeeprr.dev.db in dev.
BOOKKEEPRR_DB_PATH=./bookkeeprr.dev.db

# Where mutable config lives (DB file, backups, logs)
BOOKKEEPRR_CONFIG_DIR=./.config

# Parent of /downloads and /comics etc on disk
BOOKKEEPRR_MEDIA_ROOT=./.media

# HTTP port for the Next.js process
BOOKKEEPRR_PORT=3000

# fatal | error | warn | info | debug | trace
BOOKKEEPRR_LOG_LEVEL=info
