{
  "name": "@bookkeeprr/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "concurrently -n web,worker -c blue,magenta \"pnpm dev:web\" \"pnpm dev:worker\"",
    "dev:web": "next dev --turbo",
    "dev:worker": "tsx watch --include=.env --env-file=.env src/worker.ts",
    "build": "next build && pnpm build:worker && pnpm build:reset-script",
    "build:worker": "esbuild src/worker.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/worker.cjs --external:better-sqlite3 --external:pino --external:pino-roll --external:pino-pretty --external:pino-worker --external:pino-file --external:thread-stream --external:@node-rs/argon2",
    "build:reset-script": "esbuild scripts/reset-user-password.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/reset-user-password.cjs --external:better-sqlite3 --external:@node-rs/argon2",
    "start": "next start",
    "start:worker": "node dist/worker.cjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration --passWithNoTests",
    "test:e2e": "tsx scripts/e2e-run.ts",
    "test:e2e:headed": "BOOKKEEPRR_E2E_HEADED=1 tsx scripts/e2e-run.ts",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "openapi:emit": "tsx scripts/emit-openapi.ts"
  },
  "dependencies": {
    "@bookkeeprr/logic": "workspace:^",
    "@bookkeeprr/tokens": "workspace:^",
    "@bookkeeprr/types": "workspace:^",
    "@bookkeeprr/ui": "workspace:^",
    "@hookform/resolvers": "^5.4.0",
    "@node-rs/argon2": "^2.0.2",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-toggle": "^1.1.11",
    "@radix-ui/react-toggle-group": "^1.1.12",
    "@stoplight/elements": "^9.0.22",
    "@stoplight/mosaic": "^1.53.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-virtual": "^3.14.2",
    "async-mutex": "^0.5.0",
    "bencode": "^4.0.1",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.8.0",
    "foliate-js": "^1.0.1",
    "ipaddr.js": "^2.4.0",
    "jose": "^6.2.3",
    "js-md5": "^0.8.3",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "openid-client": "^6.8.4",
    "otpauth": "^9.5.1",
    "p-limit": "^7.3.0",
    "pdfjs-dist": "^6.0.227",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.78.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "undici": "7.27.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.7",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.2",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.7",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
